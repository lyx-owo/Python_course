            "請輸入水果apple\n",
            "這個水果已經有了\n"
          ]
        }
      ],
      "source": [
        "fruits=['apple','banana','watermelon']\n",
        "fruit=input(\"請輸入水果\")\n",
        "if fruit in fruits:\n",
        "    print('這個水果已經有了')\n",
        "else:\n",
        "    fruits.append(fruit)\n",
        "    print('謝謝提醒已加入水果清單:',fruits)"
