      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "99 94 93 91 88 "
          ]
        }
      ],
      "source": [
        "scores=[94,82,60,91,88,79,61,93,99,77]\n",
        "scores.sort(reverse=True)\n",
        "count=0\n",
        "for sc in scores:\n",
        "    count+=1\n",
        "    print(sc,end=\" \")\n",
        "    if count==5:\n",
        "        break"
      ]
    }
